{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromptX Frontmatter",
  "description": "Schema for the YAML frontmatter of a .promptx prompt file.",
  "type": "object",
  "required": ["type"],
  "properties": {
    "description": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["prompt", "chat"]
    }
  },
  "additionalProperties": false
}